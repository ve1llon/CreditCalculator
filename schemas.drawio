        <mxCell id="HpUXkBQeH3rvr4GI6Rbv-1" parent="1" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;glass=0;rounded=0;shadow=0;swimlaneLine=1;swimlaneFillColor=none;gradientColor=none;fontSize=16;" value="&lt;b&gt;Команда&lt;/b&gt;" vertex="1">
